        "# -----------------------------\n",
        "def clean_text(text):\n",
        "    text = re.sub(r'\\s+', ' ', str(text))\n",
        "    return text.lower().strip()\n",
        "\n",
        "\n",
        "# -----------------------------\n",
        "# قراءة الملف\n",
        "# -----------------------------\n",
        "def read_pdf(path):\n",
        "    text = \"\"\n",
        "    reader = PdfReader(path)\n",
        "    for page in reader.pages:\n",
        "        if page.extract_text():\n",
        "            text += page.extract_text()\n",
        "    return text\n",
        "\n",
        "\n",
        "def read_docx(path):\n",
        "    doc = docx.Document(path)\n",
        "    text = []\n",
        "    for p in doc.paragraphs:\n",
        "        text.append(p.text)\n",
        "    return \"\\n\".join(text)\n",
        "\n",
        "\n",
        "def read_txt(path):\n",
        "    with open(path,\"r\",encoding=\"utf-8\") as f:\n",
        "        return f.read()\n",
        "\n",
        "\n",
        "# -----------------------------\n",
        "# استخراج المهارات من النص\n",
        "# -----------------------------\n",
        "def extract_skills(text):\n",
        "\n",
        "    found = []\n",
        "\n",
        "    for skill in skills_list:\n",
        "        if skill in text:\n",
        "            found.append(skill)\n",
        "\n",
        "    return found\n",
        "\n",
        "\n",
        "# -----------------------------\n",
        "# تحميل ملفات السيرة الذاتية\n",
        "# -----------------------------\n",
        "def load_resumes(folder):\n",
        "\n",
        "    data = []\n",
        "\n",
        "    for file in os.listdir(folder):\n",
        "\n",
        "        path = os.path.join(folder,file)\n",
        "\n",
        "        if file.endswith(\".pdf\"):\n",
        "            text = read_pdf(path)\n",
        "\n",
        "        elif file.endswith(\".docx\"):\n",
        "            text = read_docx(path)\n",
        "\n",
        "        elif file.endswith(\".txt\"):\n",
        "            text = read_txt(path)\n",
        "\n",
        "        else:\n",
        "            continue\n",
        "\n",
        "        text = clean_text(text)\n",
        "\n",
        "        skills = extract_skills(text)\n",
        "\n",
        "        data.append({\n",
        "            \"candidate\":file,\n",
        "            \"text\":text,\n",
        "            \"skills\":skills\n",
        "        })\n",
        "\n",
        "    return pd.DataFrame(data)\n",
        "\n",
        "\n",
        "# -----------------------------\n",
        "# مواصفات الوظيفة\n",
        "# -----------------------------\n",
        "job_description = \"\"\"\n",
        "Junior Backend Developer with Python, REST APIs,\n",
        "databases and Django experience.\n",
        "\"\"\"\n",
        "\n",
        "job_description = clean_text(job_description)\n",
        "\n",
        "job_skills = extract_skills(job_description)\n",
        "\n",
        "\n",
        "# -----------------------------\n",
        "# LOAD RESUMES\n",
        "# -----------------------------\n",
        "folder = \"/content\"\n",
        "df = load_resumes(folder)\n",
        "\n",
        "\n",
        "# -----------------------------\n",
        "# LOAD MODEL\n",
        "# -----------------------------\n",
        "model = SentenceTransformer('all-MiniLM-L6-v2')\n",
        "\n",
        "\n",
        "# -----------------------------\n",
        "# EMBEDDINGS\n",
        "# -----------------------------\n",
        "job_emb = model.encode([job_description])\n",
        "resume_emb = model.encode(df[\"text\"].tolist())\n",
        "\n",
        "\n",
        "# -----------------------------\n",
        "# التشابه\n",
        "# -----------------------------\n",
        "similarity = cosine_similarity(job_emb,resume_emb).flatten()\n",
        "\n",
        "df[\"semantic_score\"] = similarity\n",
        "\n",
        "\n",
        "# -----------------------------\n",
        "# SKILls\n",
        "# -----------------------------\n",
        "skill_scores = []\n",
        "\n",
        "for skills in df[\"skills\"]:\n",
        "\n",
        "    match = len(set(skills) & set(job_skills))\n",
        "\n",
        "    score = match / len(job_skills) if job_skills else 0\n",
        "\n",
        "    skill_scores.append(score)\n",
        "\n",
        "df[\"skill_score\"] = skill_scores\n",
        "\n",
        "def read_pdf(path):\n",
        "    text = \"\"\n",
        "    try:\n",
        "        reader = PdfReader(path)\n",
        "        for page in reader.pages:\n",
        "            if page.extract_text():\n",
        "                text += page.extract_text()\n",
        "    except Exception as e:\n",
        "        print(f\"❌ مشكلة في PDF: {path} بسبب: {e}\")\n",
        "        return \"\"\n",
        "    return text\n",
        "# -----------------------------\n",
        "# FINAL SCORE\n",
        "# -----------------------------\n",
        "df[\"final_score\"] = (df[\"semantic_score\"]*0.7) + (df[\"skill_score\"]*0.3)\n",
        "\n",
        "\n",
        "# -----------------------------\n",
        "# SORT RESULTS\n",
        "# -----------------------------\n",
        "df = df.sort_values(\"final_score\",ascending=False)\n",
        "\n",
        "\n",
        "# -----------------------------\n",
        "# PRINT RESULTS\n",
        "# -----------------------------\n",
        "print(\"\\nTOP CANDIDATES\\n\")\n",
        "\n",
        "for i,row in enumerate(df.itertuples(),1):\n",
        "\n",
        "    print(f\"{i}. {row.candidate}\")\n",
        "    print(f\"Semantic Score: {round(row.semantic_score*100,2)}%\")\n",
        "    print(f\"Skill Score: {round(row.skill_score*100,2)}%\")\n",
        "    print(f\"Final Score: {round(row.final_score*100,2)}%\")\n",
        "    print(f\"Skills Found: {row.skills}\\n\")"
      ],
